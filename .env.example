# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Local development (requires: npx supabase start):
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Production — Transaction pooler (port 6543) for runtime queries:
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Production — Direct connection (port 5432) for migrations only:
# Used in Vercel build command via MIGRATION_DATABASE_URL
# MIGRATION_DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Local development (from: npx supabase status):
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-local-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-local-secret-key"

# Production — found in Supabase dashboard → Settings → API:
# NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-publishable-key"
# SUPABASE_SERVICE_ROLE_KEY="your-secret-key"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# Development: http://localhost:3000
# Production:  your public HTTPS URL — must match the OAuth redirect URI
AUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/
# Authorized JavaScript origins:    https://yourapp.com
# Authorized redirect URIs:         https://yourapp.com/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Google AI (Gemini) ────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY="your-google-ai-api-key"
# Set to "true" to enable AI receipt parsing (feature flag for subscriptions)
NEXT_PUBLIC_RECEIPT_AI_ENABLED="false"